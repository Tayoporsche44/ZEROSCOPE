<%- include('partials/header') %>

<main class="max-w-7xl mx-auto px-6 py-10">

  <!-- Page Header -->
  <div class="mb-10 flex items-start justify-between">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-zinc-100">
        Live <span class="text-acid">Opportunities</span>
      </h1>
      <p class="text-zinc-500 text-sm mt-1 font-mono">
        Zero Authority DAO — Active bounty feed
        <% if (fromCache) { %>
          <span class="ml-2 text-yellow-500">[mock data — API unreachable]</span>
        <% } %>
      </p>
    </div>
    <a href="/bookmarks"
       class="acid-border acid-glow text-acid font-mono text-xs px-4 py-2 rounded hover:bg-acid hover:text-void transition-all">
      View Bookmarks →
    </a>
  </div>

  <!-- ── Analytics Strip ─────────────────────────────────── -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
    <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-5 card-hover">
      <div class="font-mono text-xs text-zinc-500 uppercase tracking-widest mb-1">Total</div>
      <div class="text-3xl font-bold text-zinc-100"><%= analytics.totalOpportunities %></div>
      <div class="text-xs text-zinc-600 mt-1">Opportunities</div>
    </div>
    <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-5 card-hover">
      <div class="font-mono text-xs text-zinc-500 uppercase tracking-widest mb-1">Open</div>
      <div class="text-3xl font-bold text-acid"><%= analytics.openCount %></div>
      <div class="text-xs text-zinc-600 mt-1">Ready to apply</div>
    </div>
    <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-5 card-hover">
      <div class="font-mono text-xs text-zinc-500 uppercase tracking-widest mb-1">Saved</div>
      <div class="text-3xl font-bold text-zinc-100"><%= analytics.totalBookmarks %></div>
      <div class="text-xs text-zinc-600 mt-1">Bookmarks</div>
    </div>
    <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-5 card-hover">
      <div class="font-mono text-xs text-zinc-500 uppercase tracking-widest mb-1">Reward Pool</div>
      <div class="text-3xl font-bold text-zinc-100"><%= analytics.totalRewardPool %></div>
      <div class="text-xs text-zinc-600 mt-1">ZRO (open only)</div>
    </div>
  </div>

  <!-- ── Opportunity Feed ────────────────────────────────── -->
  <% if (!opportunities || opportunities.length === 0) { %>
    <div class="border border-zinc-800 rounded-lg p-12 text-center">
      <p class="text-zinc-500 font-mono text-sm">No opportunities found at this time.</p>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
      <% opportunities.forEach(function(opp) { %>
        <%
          const isBookmarked = bookmarkedIds.includes(opp.id);
          const statusColor = opp.status === 'open'
            ? 'text-acid'
            : opp.status === 'in-progress'
              ? 'text-yellow-400'
              : 'text-zinc-500';
        %>
        <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-5 flex flex-col justify-between card-hover">

          <!-- Top Section -->
          <div>
            <!-- Category + Status -->
            <div class="flex items-center justify-between mb-3">
              <span class="tag"><%= opp.category %></span>
              <span class="font-mono text-xs <%= statusColor %> uppercase tracking-wider">
                ● <%= opp.status %>
              </span>
            </div>

            <!-- Title -->
            <h2 class="text-sm font-semibold text-zinc-100 leading-snug mb-2 line-clamp-2">
              <%= opp.title %>
            </h2>

            <!-- Description -->
            <p class="text-zinc-500 text-xs leading-relaxed line-clamp-3 mb-3">
              <%= opp.description %>
            </p>

            <!-- Tags -->
            <% if (opp.tags && opp.tags.length > 0) { %>
              <div class="flex flex-wrap gap-1 mb-4">
                <% opp.tags.slice(0, 3).forEach(function(tag) { %>
                  <span class="tag"><%= tag %></span>
                <% }); %>
              </div>
            <% } %>
          </div>

          <!-- Bottom Section -->
          <div>
            <!-- Reward -->
            <div class="flex items-center justify-between mb-4 pt-3 border-t border-zinc-800">
              <div>
                <span class="font-mono text-lg font-bold text-acid"><%= opp.reward %></span>
                <span class="font-mono text-xs text-zinc-500 ml-1"><%= opp.rewardToken %></span>
              </div>
              <% if (opp.deadline) { %>
                <span class="font-mono text-xs text-zinc-600">
                  Due <%= new Date(opp.deadline).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
                </span>
              <% } %>
            </div>

            <!-- Actions -->
            <div class="flex gap-2">
              <% if (opp.url) { %>
                <a href="<%= opp.url %>" target="_blank" rel="noopener noreferrer"
                   class="flex-1 text-center text-xs font-mono py-2 rounded border border-zinc-700
                          text-zinc-400 hover:text-zinc-100 hover:border-zinc-500 transition-colors">
                  View →
                </a>
              <% } %>

              <% if (isBookmarked) { %>
                <span class="flex-1 text-center text-xs font-mono py-2 rounded
                             border border-acid/30 text-acid/60 cursor-default">
                  ✓ Saved
                </span>
              <% } else { %>
                <form action="/bookmarks" method="POST" class="flex-1">
                  <input type="hidden" name="opportunityId" value="<%= opp.id %>" />
                  <input type="hidden" name="title"         value="<%= opp.title %>" />
                  <input type="hidden" name="description"   value="<%= opp.description %>" />
                  <input type="hidden" name="reward"        value="<%= opp.reward %>" />
                  <input type="hidden" name="rewardToken"   value="<%= opp.rewardToken %>" />
                  <input type="hidden" name="status"        value="<%= opp.status %>" />
                  <input type="hidden" name="category"      value="<%= opp.category %>" />
                  <input type="hidden" name="url"           value="<%= opp.url %>" />
                  <% if (opp.postedAt) { %>
                    <input type="hidden" name="postedAt" value="<%= opp.postedAt %>" />
                  <% } %>
                  <% if (opp.deadline) { %>
                    <input type="hidden" name="deadline" value="<%= opp.deadline %>" />
                  <% } %>
                  <button type="submit"
                          class="w-full text-xs font-mono py-2 rounded acid-border text-acid
                                 hover:bg-acid hover:text-void transition-all">
                    + Bookmark
                  </button>
                </form>
              <% } %>
            </div>
          </div>

        </div>
      <% }); %>
    </div>
  <% } %>

</main>

<%- include('partials/footer') %>
